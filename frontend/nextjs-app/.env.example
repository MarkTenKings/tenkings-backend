# Base URLs for public API access used by the operator console.
# Update these when deploying behind Traefik/production load balancers.
NEXT_PUBLIC_WALLET_SERVICE_URL=http://localhost:8080
NEXT_PUBLIC_VAULT_SERVICE_URL=http://localhost:8181
NEXT_PUBLIC_MARKETPLACE_SERVICE_URL=http://localhost:8082
NEXT_PUBLIC_PRICING_SERVICE_URL=http://localhost:8182
NEXT_PUBLIC_PACK_SERVICE_URL=http://localhost:8183
NEXT_PUBLIC_INGESTION_SERVICE_URL=http://localhost:8184
NEXT_PUBLIC_VENDING_SERVICE_URL=http://localhost:8185
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8088
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-only operator key for service-to-service requests.
# Do not expose this via a NEXT_PUBLIC_ variable.
OPERATOR_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Optional explicit public override for the browser widget.
# If omitted, Next.js exposes ELEVENLABS_AGENT_ID to the client bundle at build time via next.config.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
ELEVENLABS_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
MUX_SIMULCAST_TARGETS=[]

# AI Grader production publication/runtime gates.
# Keep service credentials server-only. Store only the SHA-256 hash of the service token.
AI_GRADER_PRODUCTION_PUBLISH_ENABLED=false
AI_GRADER_PUBLIC_REPORT_DB_ENABLED=false
AI_GRADER_PUBLIC_REPORT_BASE_URL=http://localhost:3000
AI_GRADER_PRODUCTION_TENANT_ID=ten-kings
AI_GRADER_EBAY_COMPS_ENABLED=false
# Additive server-side inventory policy. Keep false until the reviewed NFC
# migration is applied and the finishing workstation helper is installed.
AI_GRADER_NFC_REQUIRED=false
# Independent server-side programming gate. Status and admin revocation remain
# available while false; init, complete, and replacement fail closed.
AI_GRADER_NFC_PROGRAMMING_ENABLED=false
# Server-only entropy used to derive one-time programming attempt tokens. Set a
# random value of at least 32 bytes before enabling hosted NFC programming.
AI_GRADER_NFC_ATTEMPT_TOKEN_SECRET=
# Server-only JSON allowlist, at most 16 KiB/eight entries. Each lowercase
# SHA-256 DER-SPKI key ID maps to exact tenantId, algorithm, and standard-base64
# publicSpkiDerBase64 fields. Never place a private workstation key here.
AI_GRADER_NFC_WORKSTATION_PUBLIC_KEYS_JSON=
AI_GRADER_OPERATOR_USER_IDS=
AI_GRADER_OPERATOR_PHONES=
AI_GRADER_ADMIN_USER_IDS=
AI_GRADER_ADMIN_PHONES=
AI_GRADER_SERVICE_ACCOUNT_ID=
AI_GRADER_SERVICE_ACCOUNT_TOKEN_SHA256=
AI_GRADER_SERVICE_ACCOUNT_SCOPES=publish,history,card-search,upload-slab-photo,run-comps
CARD_STORAGE_MODE=local
CARD_STORAGE_LOCAL_ROOT=
CARD_STORAGE_PUBLIC_PREFIX=/uploads/cards
CARD_STORAGE_BUCKET=
CARD_STORAGE_REGION=
CARD_STORAGE_ENDPOINT=
CARD_STORAGE_PUBLIC_BASE_URL=
CARD_STORAGE_ACCESS_KEY_ID=
CARD_STORAGE_SECRET_ACCESS_KEY=
CARD_STORAGE_FORCE_PATH_STYLE=false
CARD_STORAGE_ACL=public-read
SERPAPI_KEY=

# Optional default base URL (used when a service-specific override is missing).
# NEXT_PUBLIC_API_BASE_URL=http://localhost

# Live rip kiosk configuration
NEXT_PUBLIC_KIOSK_API_SECRET=
NEXT_PUBLIC_KIOSK_COUNTDOWN_SECONDS=10
NEXT_PUBLIC_KIOSK_LIVE_SECONDS=60
