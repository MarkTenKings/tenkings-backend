<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <AssemblyName>tenkings-ai-grader-pylon-worker</AssemblyName>
    <RootNamespace>TenKings.AiGrader.Pylon.Host</RootNamespace>
    <EnablePylonCompile Condition="'$(EnablePylonCompile)' == ''">false</EnablePylonCompile>
    <DefineConstants Condition="'$(EnablePylonCompile)' == 'true'">$(DefineConstants);PYLON_SDK</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\TenKings.AiGrader.Worker.Core\TenKings.AiGrader.Worker.Core.csproj" />
    <ProjectReference Include="..\TenKings.AiGrader.Vision\TenKings.AiGrader.Vision.csproj" />
    <PackageReference Include="OpenCvSharp4" />
    <PackageReference Include="OpenCvSharp4.runtime.win" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="TenKings.AiGrader.Worker.Tests" />
  </ItemGroup>
  <ItemGroup Condition="'$(EnablePylonCompile)' == 'true'">
    <Reference Include="Basler.Pylon">
      <HintPath>$(PylonAssemblyPath)</HintPath>
      <!-- Managed wrapper is copied only to ignored build/publish output.
           The installed licensed native Pylon runtime remains an external prerequisite. -->
      <Private>true</Private>
    </Reference>
  </ItemGroup>
  <Target Name="ValidatePylonSdk" BeforeTargets="ResolveReferences" Condition="'$(EnablePylonCompile)' == 'true'">
    <Error Condition="'$(PylonAssemblyPath)' == '' or !Exists('$(PylonAssemblyPath)')"
           Text="Basler.Pylon.dll was not resolved. Use the guarded build/package script with one explicit or unambiguous installed SDK assembly. The DLL is never copied into git." />
  </Target>
  <Target Name="ValidatePylonPublishDependencies"
          AfterTargets="Publish"
          Condition="'$(EnablePylonCompile)' == 'true'">
    <ItemGroup>
      <_PublishedOpenCvNative Include="$(PublishDir)**\OpenCvSharpExtern.dll" />
    </ItemGroup>
    <Error Condition="!Exists('$(PublishDir)Basler.Pylon.dll')"
           Text="Published Pylon package is missing the installed managed Basler.Pylon dependency." />
    <Error Condition="!Exists('$(PublishDir)OpenCvSharp.dll')"
           Text="Published Pylon package is missing OpenCvSharp.dll." />
    <Error Condition="'@(_PublishedOpenCvNative)' == ''"
           Text="Published Pylon package is missing the pinned Windows OpenCvSharp native runtime." />
  </Target>
</Project>
