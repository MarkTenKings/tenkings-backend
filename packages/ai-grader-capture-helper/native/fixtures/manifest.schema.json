{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenkings.local/schemas/ai-grader-replay-manifest-v1.json",
  "title": "Ten Kings AI Grader redacted replay manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "seed", "corpusKind", "cases", "missingRealCorpusCategories"],
  "properties": {
    "schemaVersion": { "const": "tenkings.ai-grader.replay-manifest.v1" },
    "seed": { "type": "integer" },
    "corpusKind": { "enum": ["synthetic", "private", "mixed"] },
    "missingRealCorpusCategories": { "type": "array", "items": { "type": "string", "maxLength": 160 }, "maxItems": 100 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pairId", "side", "category", "expectedCard", "polarity", "rotationDegrees", "perspective", "translationX", "translationY", "clipping", "borderContrast", "effects", "previewEpoch", "sideEpoch"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,95}$" },
          "pairId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,95}$" },
          "side": { "enum": ["Front", "Back"] },
          "category": { "type": "string", "maxLength": 96 },
          "expectedCard": { "type": "boolean" },
          "polarity": { "enum": ["dark_on_light", "light_on_dark", "neutral"] },
          "rotationDegrees": { "type": "number", "minimum": -35, "maximum": 35 },
          "perspective": { "type": "number", "minimum": -0.3, "maximum": 0.3 },
          "translationX": { "type": "number", "minimum": -1, "maximum": 1 },
          "translationY": { "type": "number", "minimum": -1, "maximum": 1 },
          "clipping": { "type": "number", "minimum": 0, "maximum": 1 },
          "borderContrast": { "type": "number", "minimum": 0, "maximum": 255 },
          "effects": { "type": "array", "items": { "type": "string", "maxLength": 48 }, "maxItems": 20 },
          "previewEpoch": { "type": "integer", "minimum": 0 },
          "sideEpoch": { "type": "integer", "minimum": 0 },
          "frozenOf": { "type": ["string", "null"], "maxLength": 96 },
          "privateFile": { "type": ["string", "null"], "maxLength": 240 },
          "permittedSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
