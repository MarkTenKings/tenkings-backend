{
  "name": "@tenkings/ai-grader-capture-helper",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tk-ai-grader-capture-helper": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @tenkings/ai-grader-simulator build && tsc -p .",
    "test": "pnpm run build && node --test tests/*.test.js",
