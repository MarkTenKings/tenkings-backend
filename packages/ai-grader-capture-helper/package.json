{
  "name": "@tenkings/ai-grader-capture-helper",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tk-ai-grader-capture-helper": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./drivers": {
      "types": "./dist/drivers/index.d.ts",
      "default": "./dist/drivers/index.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./dist/transport.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @tenkings/ai-grader-simulator build && tsc -p .",
    "test": "pnpm run build && node --test tests",
    "health": "node dist/cli.js health",
    "capabilities": "node dist/cli.js capabilities",
    "serve": "node dist/cli.js serve",
    "native:restore": "powershell -NoProfile -ExecutionPolicy Bypass -File native/scripts/restore-locked.ps1",
    "native:build": "dotnet build native/TenKings.AiGrader.NativeCamera.sln --configuration Release --no-restore --disable-build-servers -m:1",
    "native:test": "powershell -NoProfile -ExecutionPolicy Bypass -File native/scripts/test-fake-replay.ps1",
    "native:replay": "dotnet run --project native/src/TenKings.AiGrader.Replay/TenKings.AiGrader.Replay.csproj --configuration Release --no-restore --",
    "native:replay:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File native/scripts/verify-replay-report.ps1",
    "native:build:pylon": "powershell -NoProfile -ExecutionPolicy Bypass -File native/scripts/build-pylon-host.ps1",
    "native:package": "powershell -NoProfile -ExecutionPolicy Bypass -File native/scripts/publish-workers.ps1",
    "native:package:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File native/scripts/verify-native-package.ps1 -OutputRoot native/publish",
    "native:sharp-comparator": "node dist/drivers/nativeCameraSharpComparator.js"
  },
  "dependencies": {
    "@tenkings/ai-grader-simulator": "workspace:*",
    "@tenkings/shared": "workspace:*",
    "sharp": "^0.34.5",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4"
  }
}
