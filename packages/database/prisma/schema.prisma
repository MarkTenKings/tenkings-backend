model User {
  id                      String                @id @default(uuid())
  email                   String?               @unique
  phone                   String?               @unique
  phoneVerifiedAt         DateTime?
  dateOfBirth             DateTime?
  displayName             String?
  avatarUrl               String?
  role                    String                @default("user")
  createdAt               DateTime              @default(now())
  wallet                  Wallet?
  items                   Item[]
  ownerships              ItemOwnership[]
  listings                Listing[]             @relation("SellerListings")
  shippingRequests        ShippingRequest[]
  packs                   PackInstance[]
  packedPacks             PackInstance[]        @relation("PackedByUser")
  loadedPacks             PackInstance[]        @relation("LoadedByUser")
  ingestions              IngestionTask[]
  cardBatches             CardBatch[]
  cardNotes               CardNote[]
  reviewedCards           CardAsset[]           @relation("CardAssetHumanReviewer")
  createdEvidenceItems    CardEvidenceItem[]    @relation("CardEvidenceCreatedBy")
  createdPhotos           CardPhoto[]           @relation("CardPhotoCreatedBy")
  inventoryBatchesCreated InventoryBatch[]      @relation("InventoryBatchCreatedBy")
  autoFillSessionsCreated AutoFillSession[]     @relation("AutoFillSessionCreatedBy")
  packRecipesCreated      PackRecipe[]          @relation("PackRecipeCreatedBy")
  bytebotPlaybookRules    BytebotPlaybookRule[]
  sessions                Session[]
  qrCodesCreated          QrCode[]              @relation("QrCodeCreatedBy")
  qrCodesBound            QrCode[]              @relation("QrCodeBoundBy")
  kioskSessions           KioskSession[]        @relation("KioskSessionUser")
  kioskClaims             KioskSession[]        @relation("KioskClaimedBy")
  liveRips                LiveRip[]             @relation("LiveRipUser")
  liveRipConsents         LiveRipConsent[]
  scannedGoldenTickets    GoldenTicket[]        @relation("GoldenTicketScanner")
  goldenTicketConsents    GoldenTicketConsent[]
  batchStageEvents        BatchStageEvent[]
  locationRestocks        LocationRestock[]
  setIngestionJobsCreated SetIngestionJob[]     @relation("SetIngestionJobCreatedBy")
  setDraftsCreated        SetDraft[]            @relation("SetDraftCreatedBy")
  setDraftsArchived       SetDraft[]            @relation("SetDraftArchivedBy")
  setDraftVersionsCreated SetDraftVersion[]     @relation("SetDraftVersionCreatedBy")
  setApprovals            SetApproval[]         @relation("SetApprovalApprovedBy")
  setSeedJobsRequested    SetSeedJob[]          @relation("SetSeedJobRequestedBy")
  setAuditEvents          SetAuditEvent[]       @relation("SetAuditEventActor")
  ocrRegionTemplates      OcrRegionTemplate[]   @relation("OcrRegionTemplateCreatedBy")
  ocrRegionTeachEvents    OcrRegionTeachEvent[] @relation("OcrRegionTeachEventCreatedBy")
  supportCustomers        SupportCustomer[]
  stockerProfile          StockerProfile?
}

model Location {
  id                 String              @id @default(uuid())
  slug               String              @unique
  name               String
  description        String?
  address            String
  mapsUrl            String?
  mediaUrl           String?
  recentRips         Json                @db.JsonB
  muxStreamId        String?
  muxStreamKey       String?
  muxPlaybackId      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  liveRips           LiveRip[]
  kioskSessions      KioskSession[]
  packInstances      PackInstance[]
  items              Item[]
  qrCodes            QrCode[]
  packLabels         PackLabel[]
  restocks           LocationRestock[]
  inventoryBatches   InventoryBatch[]
  autoFillSessions   AutoFillSession[]
  packRecipes        PackRecipe[]
  locationType       String?
  locationStatus     String?             @default("active")
  latitude           Float?
  longitude          Float?
  venueCenterLat     Float?
  venueCenterLng     Float?
  geofenceRadiusM    Int?                @default(500)
  machineLat         Float?
  machineLng         Float?
  machineGeofenceM   Int?                @default(20)
  city               String?
  state              String?
  zip                String?
  hours              String?
  hasIndoorMap       Boolean             @default(false)
  walkingDirections  Json?               @db.JsonB
  walkingTimeMin     Int?
  landmarks          String[]            @default([])
  machinePhotoUrl    String?
  venueMapData       Json?               @db.JsonB
  checkpoints        Json?               @db.JsonB
  navigationSessions NavigationSession[]
  locationVisits     LocationVisit[]
  supportConversations Conversation[]
  stockerStops         StockerStop[]
  goldenTicketSource GoldenTicket[]

  @@index([state])
  @@index([locationType])
  @@index([locationStatus])
}

model StockerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  language  String   @default("en")
  isActive  Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts    StockerShift[]
  positions StockerPosition[]

  @@index([isActive])
  @@map("stocker_profiles")
}

model StockRoute {
  id              String   @id @default(uuid())
  name            String
  description     String?
  locationIds     String[]
  totalDistanceM  Int?
  totalDurationS  Int?
  encodedPolyline String?  @db.Text
  legsData        Json?
  isTemplate      Boolean  @default(false)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shifts          StockerShift[]

  @@index([isTemplate])
  @@map("stock_routes")
}

model StockerShift {
  id                 String         @id @default(uuid())
  stockerId          String
  stocker            StockerProfile @relation(fields: [stockerId], references: [id], onDelete: Cascade)
  routeId            String
  route              StockRoute     @relation(fields: [routeId], references: [id])
  assignedDate       DateTime       @db.Date
  status             String         @default("pending")
  clockInAt          DateTime?
  clockOutAt         DateTime?
  totalDriveTimeMin  Int?
  totalOnSiteTimeMin Int?
  totalIdleTimeMin   Int?
  totalDistanceM     Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  stops              StockerStop[]

  @@index([stockerId, assignedDate])
  @@index([status])
  @@index([assignedDate])
  @@map("stocker_shifts")
}

model StockerStop {
  id                 String       @id @default(uuid())
  shiftId            String
  shift              StockerShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  locationId         String       @db.Uuid
  location           Location     @relation(fields: [locationId], references: [id])
  stopOrder          Int
  status             String       @default("pending")
  departedPreviousAt DateTime?
  arrivedAt          DateTime?
  taskStartedAt      DateTime?
  taskCompletedAt    DateTime?
  departedAt         DateTime?
  driveTimeMin       Int?
  driveDistanceM     Int?
  onSiteTimeMin      Int?
  skipReason         String?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([shiftId, stopOrder])
  @@index([status])
  @@map("stocker_stops")
}

model StockerPosition {
  id                  String         @id @default(uuid())
  stockerId           String         @unique
  stocker             StockerProfile @relation(fields: [stockerId], references: [id], onDelete: Cascade)
  latitude            Float
  longitude           Float
  speed               Float?
  heading             Float?
  accuracy            Float?
  shiftId             String?
  status              String         @default("idle")
  currentLocationName String?
  updatedAt           DateTime       @updatedAt

  @@map("stocker_positions")
}

model PositionLog {
  id        String   @id @default(uuid())
  stockerId String
  shiftId   String?
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  accuracy  Float?
  timestamp DateTime @default(now())

  @@index([stockerId, timestamp])
  @@index([shiftId, timestamp])
  @@map("position_logs")
}

model LiveRip {
  id             String        @id @default(uuid())
  slug           String        @unique
  title          String
  description    String?
  videoUrl       String
  thumbnailUrl   String?
  locationId     String?
  userId         String?
  status         LiveRipStatus @default(COMPLETE)
  featured       Boolean       @default(false)
  viewCount      Int?
  muxStreamId    String?
  muxStreamKey   String?
  muxAssetId     String?
  muxPlaybackId  String?
  whipUploadUrl  String?
  isGoldenTicket Boolean       @default(false)
  goldenTicketId String?       @unique
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  location       Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user           User?         @relation("LiveRipUser", fields: [userId], references: [id], onDelete: SetNull)
  kioskSessionId String?       @unique
  kioskSession   KioskSession? @relation("KioskSessionLiveRip", fields: [kioskSessionId], references: [id], onDelete: SetNull)
  goldenTicket   GoldenTicket? @relation(fields: [goldenTicketId], references: [id], onDelete: SetNull)
  consents       LiveRipConsent[]

  @@index([isGoldenTicket, createdAt])
  @@index([status, isGoldenTicket, createdAt])
  @@index([userId])
  @@index([muxStreamId])
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balance      Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String            @id @default(uuid())
  walletId    String
  amount      Int
  type        TransactionType
  source      TransactionSource
  note        String?
  referenceId String?
  createdAt   DateTime          @default(now())
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Item {
  id                String           @id @default(uuid())
  name              String
  set               String
  number            String?
  language          String?
  foil              Boolean          @default(false)
  estimatedValue    Int?
  status            ItemStatus       @default(STORED)
  vaultLocation     String?
  imageUrl          String?
  thumbnailUrl      String?
  cdnHdUrl          String?
  cdnThumbUrl       String?
  detailsJson       Json?
  ownerId           String
  locationId        String?          @db.Uuid
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  owner             User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  location          Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  listings          Listing?
  ownerships        ItemOwnership[]
  packSlots         PackSlot[]
  ingestionTask     IngestionTask?
  shippingRequest   ShippingRequest?
  kioskReveals      KioskSession[]   @relation("KioskReveal")
  goldenTicketPrize GoldenTicket?
  cardQrCodeId      String?          @unique
  cardQrCode        QrCode?          @relation("CardQrCode", fields: [cardQrCodeId], references: [id])
  packLabels        PackLabel[]
  aiGraderNfcTags   AiGraderNfcTag[]

  @@index([locationId])
}

model AuthVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportCustomer {
  id            String         @id @default(cuid())
  phone         String?        @unique
  email         String?        @unique
  name          String?
  firstSeen     DateTime       @default(now())
  lastSeen      DateTime       @updatedAt
  preferredLang String?        @default("en")
  notes         Json?          @db.JsonB
  linkedUserId  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  linkedUser    User?          @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  customerNotes CustomerNote[]

  @@index([linkedUserId])
  @@index([createdAt])
  @@index([updatedAt])
}

model Conversation {
  id          String              @id @default(cuid())
  customerId  String
  channel     ConversationChannel
  startedAt   DateTime            @default(now())
  endedAt     DateTime?
  status      ConversationStatus  @default(OPEN)
  summary     String?
  transcript  String?
  agentId     String?
  locationId  String?             @db.Uuid
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  customer    SupportCustomer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location    Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  messages    Message[]
  escalation  Escalation?

  @@index([customerId, startedAt])
  @@index([locationId, startedAt])
  @@index([status, startedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  timestamp      DateTime     @default(now())
  sentiment      Sentiment?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
}

model Escalation {
  id             String           @id @default(cuid())
  conversationId String           @unique
  triggeredAt    DateTime         @default(now())
  resolvedAt     DateTime?
  assignedTo     String?
  status         EscalationStatus @default(PENDING)
  reminderCount  Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([status, triggeredAt])
}

model CustomerNote {
  id         String          @id @default(cuid())
  customerId String
  note       String
  source     NoteSource      @default(AI_INFERRED)
  createdAt  DateTime        @default(now())
  customer   SupportCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model SupportFAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, category])
}

model ItemOwnership {
  id         String   @id @default(uuid())
  itemId     String
  ownerId    String
  note       String?
  acquiredAt DateTime @default(now())
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Listing {
  id        String        @id @default(uuid())
  itemId    String        @unique
  sellerId  String
  price     Int
  status    ListingStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  item      Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  seller    User          @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
}

model ShippingRequest {
  id                 String         @id @default(uuid())
  itemId             String         @unique
  userId             String
  status             ShippingStatus @default(PENDING)
  recipientName      String
  addressLine1       String
  addressLine2       String?
  city               String
  state              String?
  postalCode         String
  country            String
  phone              String?
  email              String?
  processingFeeMinor Int
  shippingFeeMinor   Int
  totalFeeMinor      Int
  notes              String?
  trackingNumber     String?
  carrier            String?
  fulfilledAt        DateTime?
  isGoldenTicket     Boolean        @default(false)
  goldenTicketId     String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  item         Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goldenTicket GoldenTicket? @relation(fields: [goldenTicketId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isGoldenTicket, createdAt])
}

model PackDefinition {
  id             String              @id @default(uuid())
  name           String
  description    String?
  price          Int
  inventoryCount Int                 @default(0)
  category       CollectibleCategory @default(SPORTS)
  tier           PackTier            @default(TIER_50)
  imageUrl       String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  packs          PackInstance[]
  cardAssets     CardAsset[]
}

model PackInstance {
  id                String                @id @default(uuid())
  packDefinitionId  String
  ownerId           String?
  status            PackStatus            @default(UNOPENED)
  fulfillmentStatus PackFulfillmentStatus @default(ONLINE)
  locationId        String?
  sourceBatchId     String?
  createdAt         DateTime              @default(now())
  openedAt          DateTime?
  packedAt          DateTime?
  packedById        String?
  loadedAt          DateTime?
  loadedById        String?
  packQrCodeId      String?               @unique
  packDefinition    PackDefinition        @relation(fields: [packDefinitionId], references: [id], onDelete: Cascade)
  owner             User?                 @relation(fields: [ownerId], references: [id])
  slots             PackSlot[]
  kioskSessions     KioskSession[]
  location          Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  packedBy          User?                 @relation("PackedByUser", fields: [packedById], references: [id])
  loadedBy          User?                 @relation("LoadedByUser", fields: [loadedById], references: [id])
  packQrCode        QrCode?               @relation("PackQrCode", fields: [packQrCodeId], references: [id])
  packLabels        PackLabel[]
  goldenTickets     GoldenTicket[]
  sourceBatch       CardBatch?            @relation("PackInstanceSourceBatch", fields: [sourceBatchId], references: [id], onDelete: SetNull)
}

model KioskSession {
  id                 String             @id @default(uuid())
  code               String             @unique
  controlTokenHash   String
  userId             String?
  packInstanceId     String?
  locationId         String?
  packQrCodeId       String?
  packResetVersion   Int                @default(0)
  packQrCodeSerial   String?
  claimedById        String?
  claimStatus        KioskClaimStatus   @default(UNCLAIMED)
  status             KioskSessionStatus @default(COUNTDOWN)
  countdownSeconds   Int                @default(10)
  liveSeconds        Int                @default(30)
  revealSeconds      Int                @default(10)
  countdownStartedAt DateTime           @default(now())
  liveStartedAt      DateTime?
  revealStartedAt    DateTime?
  revealItemId       String?
  videoUrl           String?
  thumbnailUrl       String?
  qrLinkUrl          String?
  buybackLinkUrl     String?
  revealPayload      Json?
  ingestMode         KioskIngestMode    @default(OBS)
  whipUploadUrl      String?
  reactionVideoUrl   String?
  isGoldenTicket     Boolean            @default(false)
  goldenTicketId     String?            @unique
  muxStreamId        String?
  muxStreamKey       String?
  muxPlaybackId      String?
  muxAssetId         String?
  muxBroadcastId     String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  completedAt        DateTime?

  user                User?         @relation("KioskSessionUser", fields: [userId], references: [id], onDelete: SetNull)
  packInstance        PackInstance? @relation(fields: [packInstanceId], references: [id], onDelete: SetNull)
  location            Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  revealItem          Item?         @relation("KioskReveal", fields: [revealItemId], references: [id], onDelete: SetNull)
  liveRip             LiveRip?      @relation("KioskSessionLiveRip")
  packQrCode          QrCode?       @relation("SessionPackQr", fields: [packQrCodeId], references: [id])
  claimedBy           User?         @relation("KioskClaimedBy", fields: [claimedById], references: [id])
  goldenTicket        GoldenTicket? @relation("GoldenTicketSession", fields: [goldenTicketId], references: [id], onDelete: SetNull)
  claimedGoldenTicket GoldenTicket? @relation("GoldenTicketClaimedSession")

  @@index([userId])
  @@index([ingestMode, status, createdAt])
  @@index([isGoldenTicket, status, createdAt])
}

model PackSlot {
  id             String       @id @default(uuid())
  packInstanceId String
  itemId         String
  packInstance   PackInstance @relation(fields: [packInstanceId], references: [id], onDelete: Cascade)
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model IngestionTask {
  id         String          @id @default(uuid())
  externalId String?
  status     IngestionStatus @default(PENDING)
  itemId     String?         @unique
  ownerId    String
  rawPayload Json?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  item       Item?           @relation(fields: [itemId], references: [id])
  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model SetDraft {
  id              String         @id @default(uuid())
  setId           String         @unique
  normalizedLabel String?
  status          SetDraftStatus @default(DRAFT)
  archivedAt      DateTime?
  createdById     String?
  archivedById    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy     User?             @relation("SetDraftCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  archivedBy    User?             @relation("SetDraftArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  ingestionJobs SetIngestionJob[]
  versions      SetDraftVersion[]
  approvals     SetApproval[]
  seedJobs      SetSeedJob[]
  auditEvents   SetAuditEvent[]

  @@index([status])
  @@index([archivedAt])
}

model SetIngestionJob {
  id               String                @id @default(uuid())
  setId            String
  draftId          String?
  datasetType      SetDatasetType
  sourceUrl        String?
  rawPayload       Json?
  parserVersion    String
  status           SetIngestionJobStatus @default(QUEUED)
  parseSummaryJson Json?
  errorMessage     String?
  createdById      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  parsedAt         DateTime?
  reviewedAt       DateTime?

  draft           SetDraft?           @relation(fields: [draftId], references: [id], onDelete: SetNull)
  createdBy       User?               @relation("SetIngestionJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  auditEvents     SetAuditEvent[]
  taxonomySources SetTaxonomySource[]

  @@index([setId, status])
  @@index([datasetType, status])
  @@index([draftId])
}

model SetDraftVersion {
  id                 String   @id @default(uuid())
  draftId            String
  version            Int
  versionHash        String
  dataJson           Json
  validationJson     Json?
  sourceLinksJson    Json?
  rowCount           Int      @default(0)
  errorCount         Int      @default(0)
  blockingErrorCount Int      @default(0)
  createdById        String?
  createdAt          DateTime @default(now())

  draft       SetDraft        @relation(fields: [draftId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation("SetDraftVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvals   SetApproval[]
  seedJobs    SetSeedJob[]
  auditEvents SetAuditEvent[]

  @@unique([draftId, version])
  @@index([draftId, createdAt])
  @@index([versionHash])
}

model SetApproval {
  id              String              @id @default(uuid())
  draftId         String
  draftVersionId  String
  decision        SetApprovalDecision
  reason          String?
  diffSummaryJson Json?
  versionHash     String
  approvedById    String?
  createdAt       DateTime            @default(now())

  draft        SetDraft        @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftVersion SetDraftVersion @relation(fields: [draftVersionId], references: [id], onDelete: Cascade)
  approvedBy   User?           @relation("SetApprovalApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  auditEvents  SetAuditEvent[]

  @@index([draftId, createdAt])
  @@index([draftVersionId])
  @@index([decision, createdAt])
}

model SetSeedJob {
  id                String           @id @default(uuid())
  draftId           String
  draftVersionId    String?
  status            SetSeedJobStatus @default(QUEUED)
  runArgsJson       Json?
  progressJson      Json?
  resultJson        Json?
  logsJson          Json?
  queueCount        Int?
  errorMessage      String?
  requestedById     String?
  retryOfId         String?
  cancelRequestedAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  draft        SetDraft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftVersion SetDraftVersion? @relation(fields: [draftVersionId], references: [id], onDelete: SetNull)
  requestedBy  User?            @relation("SetSeedJobRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  retryOf      SetSeedJob?      @relation("SetSeedJobRetries", fields: [retryOfId], references: [id], onDelete: SetNull)
  retries      SetSeedJob[]     @relation("SetSeedJobRetries")
  auditEvents  SetAuditEvent[]

  @@index([draftId, status])
  @@index([status, createdAt])
  @@index([draftVersionId])
}

model SetAuditEvent {
  id             String         @id @default(uuid())
  setId          String?
  draftId        String?
  draftVersionId String?
  ingestionJobId String?
  approvalId     String?
  seedJobId      String?
  actorId        String?
  action         String
  status         SetAuditStatus @default(SUCCESS)
  reason         String?
  requestId      String?
  ipAddress      String?
  userAgent      String?
  metadataJson   Json?
  createdAt      DateTime       @default(now())

  draft        SetDraft?        @relation(fields: [draftId], references: [id], onDelete: SetNull)
  draftVersion SetDraftVersion? @relation(fields: [draftVersionId], references: [id], onDelete: SetNull)
  ingestionJob SetIngestionJob? @relation(fields: [ingestionJobId], references: [id], onDelete: SetNull)
  approval     SetApproval?     @relation(fields: [approvalId], references: [id], onDelete: SetNull)
  seedJob      SetSeedJob?      @relation(fields: [seedJobId], references: [id], onDelete: SetNull)
  actor        User?            @relation("SetAuditEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([setId, createdAt])
  @@index([draftId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
}

model SetTaxonomySource {
  id               String               @id @default(uuid())
  setId            String
  ingestionJobId   String?
  artifactType     TaxonomyArtifactType @default(CHECKLIST)
  sourceKind       TaxonomySourceKind
  sourceLabel      String?
  sourceUrl        String?
  parserVersion    String?
  sourceTimestamp  DateTime?
  parserConfidence Float?
  metadataJson     Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  ingestionJob    SetIngestionJob?            @relation(fields: [ingestionJobId], references: [id], onDelete: SetNull)
  programs        SetProgram[]
  cards           SetCard[]
  variations      SetVariation[]
  parallels       SetParallel[]
  parallelScopes  SetParallelScope[]
  oddsRows        SetOddsByFormat[]
  ambiguityItems  SetTaxonomyAmbiguityQueue[]
  conflictsAsBase SetTaxonomyConflict[]       @relation("TaxonomyConflictExistingSource")
  conflictsAsNext SetTaxonomyConflict[]       @relation("TaxonomyConflictIncomingSource")

  @@index([setId, createdAt])
  @@index([sourceKind, createdAt])
  @@index([ingestionJobId])
}

model SetProgram {
  id           String   @id @default(uuid())
  setId        String
  programId    String
  label        String
  codePrefix   String?
  programClass String?
  sourceId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  source         SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  cards          SetCard[]
  variations     SetVariation[]
  parallelScopes SetParallelScope[]
  oddsRows       SetOddsByFormat[]

  @@unique([setId, programId])
  @@index([setId, label])
}

model SetCard {
  id           String   @id @default(uuid())
  setId        String
  programId    String
  cardNumber   String
  playerName   String?
  team         String?
  isRookie     Boolean?
  metadataJson Json?
  sourceId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  program SetProgram         @relation(fields: [setId, programId], references: [setId, programId], onDelete: Cascade)
  source  SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([setId, programId, cardNumber])
  @@index([setId, cardNumber])
  @@index([setId, team])
}

model SetVariation {
  id          String   @id @default(uuid())
  setId       String
  programId   String
  variationId String
  label       String
  scopeNote   String?
  sourceId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program SetProgram         @relation(fields: [setId, programId], references: [setId, programId], onDelete: Cascade)
  source  SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  scopes  SetParallelScope[]

  @@unique([setId, programId, variationId])
  @@index([setId, label])
}

model SetParallel {
  id                String   @id @default(uuid())
  setId             String
  parallelId        String
  label             String
  serialDenominator Int?
  serialText        String?
  finishFamily      String?
  visualCuesJson    Json?
  sourceId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  source   SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  scopes   SetParallelScope[]
  oddsRows SetOddsByFormat[]

  @@unique([setId, parallelId])
  @@index([setId, label])
}

model SetParallelScope {
  id          String   @id @default(uuid())
  setId       String
  scopeKey    String
  parallelId  String
  programId   String
  variationId String?
  formatKey   String?
  channelKey  String?
  sourceId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program   SetProgram         @relation(fields: [setId, programId], references: [setId, programId], onDelete: Cascade)
  parallel  SetParallel        @relation(fields: [setId, parallelId], references: [setId, parallelId], onDelete: Cascade)
  variation SetVariation?      @relation(fields: [setId, programId, variationId], references: [setId, programId, variationId], onDelete: Cascade)
  source    SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([setId, scopeKey])
  @@index([setId, programId])
  @@index([setId, parallelId])
}

model SetOddsByFormat {
  id          String   @id @default(uuid())
  setId       String
  oddsKey     String
  programId   String?
  parallelId  String?
  formatKey   String?
  channelKey  String?
  oddsText    String
  oddsNumeric Float?
  sourceId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program  SetProgram?        @relation(fields: [setId, programId], references: [setId, programId], onDelete: Cascade)
  parallel SetParallel?       @relation(fields: [setId, parallelId], references: [setId, parallelId], onDelete: Cascade)
  source   SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([setId, oddsKey])
  @@index([setId, programId, parallelId])
  @@index([setId, formatKey, channelKey])
}

model SetTaxonomyConflict {
  id                String                 @id @default(uuid())
  setId             String
  entityType        TaxonomyEntityType
  entityKey         String
  conflictField     String
  existingSourceId  String?
  incomingSourceId  String?
  existingValueJson Json?
  incomingValueJson Json?
  status            TaxonomyConflictStatus @default(OPEN)
  resolutionNote    String?
  resolvedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  existingSource SetTaxonomySource? @relation("TaxonomyConflictExistingSource", fields: [existingSourceId], references: [id], onDelete: SetNull)
  incomingSource SetTaxonomySource? @relation("TaxonomyConflictIncomingSource", fields: [incomingSourceId], references: [id], onDelete: SetNull)

  @@index([setId, status, createdAt])
  @@index([setId, entityType, entityKey])
}

model SetTaxonomyAmbiguityQueue {
  id             String                  @id @default(uuid())
  setId          String
  entityType     TaxonomyEntityType
  ambiguityKey   String
  payloadJson    Json?
  sourceId       String?
  status         TaxonomyAmbiguityStatus @default(PENDING)
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  source SetTaxonomySource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([setId, ambiguityKey])
  @@index([setId, status, createdAt])
}

model SetReplaceJob {
  id                String              @id @default(uuid())
  setId             String
  datasetType       SetDatasetType
  status            SetReplaceJobStatus @default(QUEUED)
  previewHash       String
  runArgsJson       Json?
  progressJson      Json?
  resultJson        Json?
  logsJson          Json?
  errorMessage      String?
  reason            String?
  requestedById     String?
  ingestionJobId    String?
  draftId           String?
  draftVersionId    String?
  approvalId        String?
  seedJobId         String?
  activeSetLock     String?             @unique
  cancelRequestedAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([setId, createdAt])
  @@index([status, createdAt])
  @@index([requestedById, createdAt])
}

model CardBatch {
  id             String     @id @default(uuid())
  label          String?
  notes          String?
  uploadedById   String
  totalCount     Int        @default(0)
  processedCount Int        @default(0)
  status         String     @default("UPLOADING")
  stage          BatchStage @default(INVENTORY_READY)
  tags           String[]   @default([])
  stageChangedAt DateTime?  @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  uploadedBy  User              @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  cards       CardAsset[]
  packLabels  PackLabel[]
  sourcePacks PackInstance[]    @relation("PackInstanceSourceBatch")
  stageEvents BatchStageEvent[]
}

model BatchStageEvent {
  id        String     @id @default(uuid())
  batchId   String
  stage     BatchStage
  note      String?
  actorId   String?
  createdAt DateTime   @default(now())

  batch CardBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  actor User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([stage])
}

model LocationRestock {
  id         String   @id @default(uuid())
  locationId String   @db.Uuid
  operatorId String?
  countsJson Json?
  photoUrl   String?
  notes      String?
  createdAt  DateTime @default(now())

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  operator User?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([locationId])
  @@index([createdAt])
}

model CardAsset {
  id                        String               @id @default(uuid())
  batchId                   String
  storageKey                String
  fileName                  String
  fileSize                  Int
  mimeType                  String
  imageUrl                  String
  thumbnailUrl              String?
  cdnHdUrl                  String?
  cdnThumbUrl               String?
  status                    CardAssetStatus      @default(UPLOADING)
  ocrText                   String?
  ocrJson                   Json?
  ocrSuggestionJson         Json?
  ocrSuggestionUpdatedAt    DateTime?
  backgroundRemovedAt       DateTime?
  patternSignatureJson      Json?
  patternSignatureUpdatedAt DateTime?
  classificationJson        Json?
  classificationSourcesJson Json?
  valuationMinor            Int?
  valuationCurrency         String?              @default("USD")
  valuationSource           String?
  marketplaceUrl            String?
  assignedDefinitionId      String?
  assignedAt                DateTime?
  errorMessage              String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  processingStartedAt       DateTime?
  processingCompletedAt     DateTime?
  customTitle               String?
  customDetails             String?
  ebaySoldUrl               String?
  ebaySoldUrlVariant        String?
  ebaySoldUrlHighGrade      String?
  ebaySoldUrlPlayerComp     String?
  ebaySoldUrlAiGrade        String?
  humanReviewedAt           DateTime?
  humanReviewedById         String?
  sportsDbPlayerId          String?
  sportsDbMatchConfidence   Float?
  resolvedPlayerName        String?
  resolvedTeamName          String?
  playerStatsSnapshot       Json?
  aiGradingJson             Json?
  aiGradeFinal              Float?
  aiGradeLabel              String?
  aiGradePsaEquivalent      Int?
  aiGradeRangeLow           Int?
  aiGradeRangeHigh          Int?
  aiGradeGeneratedAt        DateTime?
  reviewStage               CardReviewStage?
  reviewStageUpdatedAt      DateTime?
  category                  CollectibleCategory?
  subCategory               String?
  inventoryBatchId          String?
  inventoryAssignedAt       DateTime?
  variantId                 String?
  variantConfidence         Float?

  batch                CardBatch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  assignedDefinition   PackDefinition?       @relation(fields: [assignedDefinitionId], references: [id], onDelete: SetNull)
  notes                CardNote[]
  jobs                 ProcessingJob[]
  bytebotLiteJobs      BytebotLiteJob[]
  evidenceItems        CardEvidenceItem[]
  photos               CardPhoto[]
  inventoryBatch       InventoryBatch?       @relation(fields: [inventoryBatchId], references: [id], onDelete: SetNull)
  humanReviewer        User?                 @relation("CardAssetHumanReviewer", fields: [humanReviewedById], references: [id])
  sportsDbPlayer       SportsDbPlayer?       @relation(fields: [sportsDbPlayerId], references: [id], onDelete: SetNull)
  variantDecisions     CardVariantDecision[]
  ocrFeedbackEvents    OcrFeedbackEvent[]
  ocrRegionTeachEvents OcrRegionTeachEvent[]
  aiGraderNfcTags      AiGraderNfcTag[]

  @@index([sportsDbPlayerId])
  @@index([inventoryBatchId])
  @@index([reviewStage, inventoryBatchId])
  @@index([category, reviewStage, inventoryBatchId])
  @@index([valuationMinor])
  @@index([inventoryAssignedAt])
}

model CardVariant {
  id             String                  @id @default(uuid())
  setId          String
  programId      String                  @default("base")
  cardNumber     String
  parallelId     String
  parallelFamily String?
  keywords       String[]                @default([])
  oddsInfo       String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  taxonomyMap    CardVariantTaxonomyMap?

  @@unique([setId, programId, cardNumber, parallelId])
  @@index([setId, cardNumber])
  @@index([setId, programId, cardNumber])
}

model CardVariantTaxonomyMap {
  id            String   @id @default(uuid())
  cardVariantId String   @unique
  setId         String
  programId     String?
  cardNumber    String?
  variationId   String?
  parallelId    String?
  canonicalKey  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cardVariant CardVariant @relation(fields: [cardVariantId], references: [id], onDelete: Cascade)

  @@index([setId, canonicalKey])
}

model CardVariantReferenceImage {
  id                     String    @id @default(uuid())
  setId                  String
  programId              String    @default("base")
  cardNumber             String?
  parallelId             String
  refType                String    @default("front")
  pairKey                String?
  sourceListingId        String?
  playerSeed             String?
  storageKey             String?
  qaStatus               String    @default("pending")
  ownedStatus            String    @default("external")
  promotedAt             DateTime?
  sourceUrl              String?
  listingTitle           String?
  rawImageUrl            String
  cropUrls               String[]  @default([])
  cropEmbeddings         Json?
  qualityScore           Float?
  qualityGateScore       Int?
  qualityGateStatus      String?
  qualityGateReasonsJson Json?
